{
  "name": "gypsa-api",
  "version": "1.0.0",
  "private": true,
  "description": "GYPSA API — contact form intake via email (Zoho SMTP)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "nodemailer": "^9.0.3",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3"
  }
}
