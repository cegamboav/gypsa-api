# Server
NODE_ENV=development
PORT=3001

# Comma-separated origins allowed to call the API (gypsa.tech local + prod later)
CORS_ORIGIN=http://localhost:5173

# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=contacto@gypsa.tech

# Zoho SMTP — loaded now, wired inside EmailService in the next step
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
